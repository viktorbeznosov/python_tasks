# .env

# Токен доступа к API
API_TOKEN = <your_api_key>

# Отображать лог в терминале
LOG_PRINT = 1

# Авторизация
JWT_SECRET = <your_jwt_secret>
JWT_EXPIRATION = 900

# LLM
LLM_BASE_URL = https://api.openai.com/v1/responses
LLM_MODEL = gpt-4o-mini
LLM_API_KEY = <your_api_key>

# Hugging Face
HF_TOKEN = <your_hf_token>

# Whisper
WHISPER_MODEL = small